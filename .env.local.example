# Supabase project settings — find these in your Supabase project at
# Settings > API. Copy this file to .env.local and fill in your values.
# .env.local is already gitignored (see .gitignore) and must never be committed.
#
# Supabase now calls the anon key a "publishable key" (format: sb_publishable_...).
# It works the same way as the legacy anon key — paste it into
# NEXT_PUBLIC_SUPABASE_ANON_KEY below.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
